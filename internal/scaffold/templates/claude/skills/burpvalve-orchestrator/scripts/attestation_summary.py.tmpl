#!/usr/bin/env python3
"""Summarize a Burpvalve attestation JSON file."""

import argparse
import json
from collections import Counter
from pathlib import Path


def main():
    parser = argparse.ArgumentParser(description="Print feature, hash, verdict, verifier, and transcript summary.")
    parser.add_argument("attestation", help="Path to a Burpvalve attestation JSON file")
    args = parser.parse_args()

    data = json.loads(Path(args.attestation).read_text())
    payload_hash = data.get("staged_payload_hash") or data.get("payload_hash") or data.get("binding", {}).get("staged_payload_hash", "")
    feature_ids = []
    plan = data.get("plan") or {}
    for feature in plan.get("features") or data.get("features") or []:
        if isinstance(feature, dict) and feature.get("id"):
            feature_ids.append(feature["id"])
    conditions = data.get("conditions") or data.get("verifier_responses") or []
    verdicts = Counter()
    verifiers = Counter()
    transcripts = []
    for condition in conditions:
        verdicts[condition.get("verdict", "unknown")] += 1
        verifier = condition.get("verifier") or {}
        label = "/".join(filter(None, [verifier.get("agent"), verifier.get("model"), verifier.get("runtime")]))
        if label:
            verifiers[label] += 1
        if verifier.get("transcript_ref"):
            transcripts.append(verifier["transcript_ref"])
    print("features: " + (", ".join(feature_ids) if feature_ids else "(unknown)"))
    print("payload_hash: " + payload_hash)
    print("verdicts: " + json.dumps(dict(sorted(verdicts.items())), sort_keys=True))
    print("verifiers: " + json.dumps(dict(sorted(verifiers.items())), sort_keys=True))
    print("transcripts: " + (", ".join(sorted(set(transcripts))) if transcripts else "(none)"))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
