#!/usr/bin/env bash
set -euo pipefail

if [[ -d ./cmd/burpvalve ]]; then
  BURPVALVE=(go run ./cmd/burpvalve)
  BURPVALVE_COMMAND_SOURCE=source
elif [[ -d ./tools/burpvalve ]]; then
  BURPVALVE=(go run ./tools/burpvalve)
  BURPVALVE_COMMAND_SOURCE=source
elif [[ -x ./bin/burpvalve ]]; then
  BURPVALVE=(./bin/burpvalve)
  BURPVALVE_COMMAND_SOURCE=repo-local
else
  cat >&2 <<'EOF'
burpvalve source is not available, so the bootstrap commit hook cannot run.
EOF
  exit 127
fi

COMMIT_ARGS=()
if [[ -n "${BURPVALVE_FEATURE:-}" ]]; then
  COMMIT_ARGS+=(--feature "$BURPVALVE_FEATURE")
fi
if [[ -n "${BURPVALVE_RESPONSES:-}" ]]; then
  COMMIT_ARGS+=(--responses "$BURPVALVE_RESPONSES")
fi
if [[ -n "${BURPVALVE_AGENT:-}" ]]; then
  COMMIT_ARGS+=(--agent "$BURPVALVE_AGENT")
fi
if [[ -n "${BURPVALVE_MODEL:-}" ]]; then
  COMMIT_ARGS+=(--model "$BURPVALVE_MODEL")
fi
if [[ -n "${BURPVALVE_BEAD:-}" ]]; then
  if [[ "$BURPVALVE_BEAD" == ,* || "$BURPVALVE_BEAD" == *, || "$BURPVALVE_BEAD" == *,,* ]]; then
    echo "BURPVALVE_BEAD_EMPTY_TOKEN: BURPVALVE_BEAD must be comma-separated bead IDs with no empty tokens" >&2
    exit 2
  fi
  IFS=',' read -r -a BURPVALVE_BEAD_TOKENS <<< "$BURPVALVE_BEAD"
  BURPVALVE_BEAD_UNIQUE=()
  for raw_bead in "${BURPVALVE_BEAD_TOKENS[@]}"; do
    bead="${raw_bead#"${raw_bead%%[![:space:]]*}"}"
    bead="${bead%"${bead##*[![:space:]]}"}"
    if [[ -z "$bead" ]]; then
      echo "BURPVALVE_BEAD_EMPTY_TOKEN: BURPVALVE_BEAD must be comma-separated bead IDs with no empty tokens" >&2
      exit 2
    fi
    if [[ "$bead" == *","* ]]; then
      echo "BURPVALVE_BEAD_COMMA: bead IDs in BURPVALVE_BEAD must not contain commas" >&2
      exit 2
    fi
    duplicate=false
    for seen_bead in "${BURPVALVE_BEAD_UNIQUE[@]}"; do
      if [[ "$seen_bead" == "$bead" ]]; then
        duplicate=true
        break
      fi
    done
    if [[ "$duplicate" == true ]]; then
      echo "BURPVALVE_BEAD_DUPLICATE: ignoring duplicate bead ID '$bead'" >&2
      continue
    fi
    BURPVALVE_BEAD_UNIQUE+=("$bead")
    COMMIT_ARGS+=(--bead "$bead")
  done
fi
if [[ -n "${BURPVALVE_BEAD_RATIONALE:-}" ]]; then
  COMMIT_ARGS+=(--bead-rationale "$BURPVALVE_BEAD_RATIONALE")
fi

BURPVALVE_HOOK_CONTEXT=pre-commit BURPVALVE_HOOK_COMMAND_SOURCE="$BURPVALVE_COMMAND_SOURCE" "${BURPVALVE[@]}" commit "${COMMIT_ARGS[@]}"
BURPVALVE_HOOK_CONTEXT=pre-commit BURPVALVE_HOOK_COMMAND_SOURCE="$BURPVALVE_COMMAND_SOURCE" "${BURPVALVE[@]}" lint

USER_HOOK=".githooks/pre-commit.user"
if [[ -x "$USER_HOOK" ]]; then
  "$USER_HOOK" "$@"
fi
